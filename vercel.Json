{
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    {
      "source": "/app",
      "destination": "/"
    },
    {
      "source": "/app/(.*)",
      "destination": "/"
    },
    {
      "source": "/(.*)",
      "destination": "/index-landing.html"
    }
  ]
}